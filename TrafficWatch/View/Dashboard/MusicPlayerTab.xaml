<UserControl x:Class="TrafficWatch.View.Dashboard.MusicPlayerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- استایل‌های سفارشی -->
        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45a049"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- هدر و اطلاعات ترک فعلی -->
        <Border Grid.Row="0" Background="#f5f5f5" CornerRadius="5" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- کاور آلبوم -->
                <Border Grid.Column="0" Width="120" Height="120" Background="#ddd" CornerRadius="5">
                    <Image x:Name="imgAlbumCover" Stretch="UniformToFill"/>
                </Border>
                
                <!-- اطلاعات ترک -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                    <TextBlock x:Name="lblTrackTitle" Text="No Track Playing" 
                               FontSize="20" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="lblTrackArtist" Text="Unknown Artist" 
                               FontSize="14" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBlock x:Name="lblTrackAlbum" Text="Unknown Album" 
                               FontSize="12" Foreground="#999" Margin="0,0,0,10"/>
                    
                    <!-- نوار پیشرفت -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock x:Name="lblCurrentTime" Text="0:00" Grid.Column="0" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ProgressBar x:Name="progressPlayback" Grid.Column="1" 
                                     Minimum="0" Maximum="100" Height="8" 
                                     Value="0" Margin="0,5"/>
                        <TextBlock x:Name="lblTotalTime" Text="0:00" Grid.Column="2" 
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- لیست پخش -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- نوار ابزار لیست پخش -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Add Files" Click="BtnAddFiles_Click" 
                        Style="{StaticResource PlayButtonStyle}"/>
                <Button Content="Add Folder" Click="BtnAddFolder_Click" 
                        Style="{StaticResource PlayButtonStyle}"/>
                <Button Content="Clear Playlist" Click="BtnClearPlaylist_Click" 
                        Style="{StaticResource PlayButtonStyle}" 
                        Background="#f44336"/>
                <TextBlock Text="Tracks: " VerticalAlignment="Center" Margin="15,0,5,0"/>
                <TextBlock x:Name="lblTrackCount" Text="0" VerticalAlignment="Center" 
                           FontWeight="Bold"/>
            </StackPanel>
            
            <!-- لیست ترک‌ها -->
            <ListBox x:Name="lstPlaylist" Grid.Row="1" 
                     SelectionChanged="LstPlaylist_SelectionChanged"
                     BorderBrush="#ddd" BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- آیکون نوع مدیا -->
                            <TextBlock Grid.Column="0" Text="🎵" FontSize="16" 
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            
                            <!-- عنوان و هنرمند -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Artist}" FontSize="11" 
                                           Foreground="#666" 
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            
                            <!-- مدت زمان -->
                            <TextBlock Grid.Column="2" Text="{Binding Duration, StringFormat={}{0}:{1:mm\\:ss}}" 
                                       VerticalAlignment="Center" Margin="10,0" 
                                       Foreground="#666"/>
                            
                            <!-- فرمت -->
                            <Border Grid.Column="3" Background="#e0e0e0" CornerRadius="3" 
                                    Padding="5,2">
                                <TextBlock Text="{Binding Format}" FontSize="10" 
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        
        <!-- کنترل‌های پخش -->
        <Border Grid.Row="2" Background="#f5f5f5" CornerRadius="5" Padding="15" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- تنظیمات سمت چپ -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Volume:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider x:Name="sliderVolume" Width="100" Minimum="0" Maximum="100" 
                            Value="75" ValueChanged="SliderVolume_ValueChanged"/>
                    <TextBlock x:Name="lblVolume" Text="75%" VerticalAlignment="Center" 
                               Margin="10,0,0,0" Width="35"/>
                </StackPanel>
                
                <!-- کنترل‌های اصلی پخش -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="⏮" Click="BtnPrevious_Click" Style="{StaticResource ControlButtonStyle}"/>
                    <Button x:Name="btnPlayPause" Content="▶" Click="BtnPlayPause_Click" 
                            Style="{StaticResource ControlButtonStyle}" Width="50"/>
                    <Button Content="⏹" Click="BtnStop_Click" Style="{StaticResource ControlButtonStyle}"/>
                    <Button Content="⏭" Click="BtnNext_Click" Style="{StaticResource ControlButtonStyle}"/>
                </StackPanel>
                
                <!-- تنظیمات سمت راست -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" 
                            VerticalAlignment="Center">
                    <Button x:Name="btnShuffle" Content="🔀" Click="BtnShuffle_Click" 
                            Style="{StaticResource ControlButtonStyle}" Width="40"/>
                    <Button x:Name="btnRepeat" Content="🔁" Click="BtnRepeat_Click" 
                            Style="{StaticResource ControlButtonStyle}" Width="40"/>
                    <Button Content="📡" Click="BtnStream_Click" Style="{StaticResource ControlButtonStyle}" 
                            ToolTip="Stream to Network/TV"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
