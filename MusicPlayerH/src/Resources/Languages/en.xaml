<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <!-- English -->
    
    <!-- Window Title -->
    <sys:String x:Key="WindowTitle">Music Player H - Professional Music &amp; Video Player</sys:String>
    
    <!-- Header -->
    <sys:String x:Key="HeaderTitle">🎵 Music Player H</sys:String>
    <sys:String x:Key="HeaderSubtitle">| Professional Music &amp; Video Player</sys:String>
    
    <!-- Now Playing Section -->
    <sys:String x:Key="NowPlayingTitle">Now Playing</sys:String>
    <sys:String x:Key="NoMediaText">No Media</sys:String>
    <sys:String x:Key="UnknownAlbum">Unknown Album</sys:String>
    <sys:String x:Key="NoTrackSelected">No track selected</sys:String>
    
    <!-- Playlist -->
    <sys:String x:Key="PlaylistTitle">Playlist</sys:String>
    <sys:String x:Key="AddFilesButton">➕ Add Files</sys:String>
    <sys:String x:Key="AddFolderButton">📁 Add Folder</sys:String>
    <sys:String x:Key="ClearAllButton">🗑️ Clear All</sys:String>
    
    <!-- Playback Controls -->
    <sys:String x:Key="PlayButton">▶️</sys:String>
    <sys:String x:Key="PauseButton">⏸️</sys:String>
    <sys:String x:Key="StopButton">⏹️</sys:String>
    <sys:String x:Key="NextButton">⏭️</sys:String>
    <sys:String x:Key="PreviousButton">⏮️</sys:String>
    <sys:String x:Key="MuteButton">🔊</sys:String>
    
    <!-- Connection Status -->
    <sys:String x:Key="ConnectedStatus">Connected to TrafficWatch</sys:String>
    <sys:String x:Key="DisconnectedStatus">TrafficWatch not running</sys:String>
    
    <!-- Language Menu -->
    <sys:String x:Key="LanguageMenu">🌐 Language</sys:String>
    <sys:String x:Key="LanguageFA">فارسی</sys:String>
    <sys:String x:Key="LanguageAR">العربیة</sys:String>
    <sys:String x:Key="LanguageEN">English</sys:String>
    
    <!-- Other -->
    <sys:String x:Key="UnknownArtist">Unknown Artist</sys:String>
    <sys:String x:Key="SelectFilesTitle">Select Music or Video Files</sys:String>
    <sys:String x:Key="SelectFolderTitle">Select a folder containing media files</sys:String>
    
</ResourceDictionary>
