<Window x:Class="MusicPlayerH.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="🎵 Music Player H - موزیک پلیر حرفه‌ای" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#191414">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- هدر برنامه -->
        <Border Grid.Row="0" Background="#1DB954" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="🎵 Music Player H" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="موزیک پلیر حرفه‌ای با اتصال به TrafficWatch" 
                               FontSize="14" 
                               Foreground="#E0E0E0"
                               Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" 
                             Fill="{Binding IsConnected, Converter={StaticResource BoolToBrushConverter}, FallbackValue=Gray}"
                             Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ConnectionStatus}" 
                               Foreground="White" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- محتوای اصلی -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- لیست پخش -->
            <Border Grid.Column="0" Background="#282828" CornerRadius="10" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="📋 لیست پخش" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White"
                               Margin="15,15,15,10"/>

                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding Playlist}"
                             SelectedItem="{Binding SelectedTrack}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="10,0,10,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Padding="10" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" 
                                                       Foreground="White" 
                                                       FontSize="16"
                                                       FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Artist}" 
                                                       Foreground="#B3B3B3" 
                                                       FontSize="12"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding Duration}" 
                                                   Foreground="#B3B3B3" 
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- اطلاعات آهنگ در حال پخش -->
            <Border Grid.Column="1" Background="#282828" CornerRadius="10" Margin="10,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="🎶 در حال پخش" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White"
                               Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- کاور آلبوم (نمایشی) -->
                        <Border Width="200" Height="200" Background="#535353" CornerRadius="10" Margin="0,0,0,20">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Text="🎵" FontSize="80" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Viewbox>
                        </Border>

                        <!-- اطلاعات آهنگ -->
                        <TextBlock Text="{Binding CurrentTitle}" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock Text="{Binding CurrentArtist}" 
                                   FontSize="18" 
                                   Foreground="#1DB954"
                                   TextAlignment="Center"
                                   Margin="0,0,0,5"/>
                        
                        <TextBlock Text="{Binding CurrentAlbum}" 
                                   FontSize="14" 
                                   Foreground="#B3B3B3"
                                   TextAlignment="Center"/>
                    </StackPanel>

                    <!-- نوار پیشرفت -->
                    <Grid Grid.Row="2" Margin="0,20,0,0">
                        <ProgressBar Value="{Binding CurrentProgress}" 
                                     Minimum="0" 
                                     Maximum="100"
                                     Height="5"
                                     Background="#535353"
                                     Foreground="#1DB954"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- کنترل‌های پخش -->
        <Border Grid.Row="2" Background="#282828" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- دکمه‌های کنترل -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="⏮️" 
                            Command="{Binding PreviousCommand}"
                            Width="50" Height="50"
                            FontSize="20"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,0,20,0"
                            Cursor="Hand"/>
                    
                    <Button Content="{Binding IsPlaying, Converter={StaticResource BoolToPlayPauseConverter}}" 
                            Command="{Binding PlayPauseCommand}"
                            Width="70" Height="70"
                            FontSize="28"
                            Background="#1DB954"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="35"
                            Margin="0,0,20,0"
                            Cursor="Hand"/>
                    
                    <Button Content="⏭️" 
                            Command="{Binding NextCommand}"
                            Width="50" Height="50"
                            FontSize="20"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
